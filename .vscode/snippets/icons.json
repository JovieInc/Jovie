{
  "Lucide Icon Import": {
    "prefix": "lucide",
    "body": ["import { ${1:ChevronRight} } from 'lucide-react';"],
    "description": "Import a Lucide React icon"
  },
  "Multiple Lucide Icons Import": {
    "prefix": "lucide-multi",
    "body": [
      "import { ${1:ChevronRight}, ${2:X}, ${3:Check} } from 'lucide-react';"
    ],
    "description": "Import multiple Lucide React icons"
  },
  "Lucide Icon Usage": {
    "prefix": "lucide-use",
    "body": ["<${1:ChevronRight} className=\"${2:h-5 w-5}\" />"],
    "description": "Use a Lucide React icon"
  },
  "SocialIcon Component": {
    "prefix": "socialicon",
    "body": [
      "<SocialIcon platform=\"${1|spotify,instagram,twitter,tiktok,youtube,facebook,soundcloud,discord,github|}\" className=\"${2:h-5 w-5}\" />"
    ],
    "description": "Use the SocialIcon component"
  },
  "SocialIcon Import": {
    "prefix": "socialicon-import",
    "body": ["import { SocialIcon } from '@/components/atoms/SocialIcon';"],
    "description": "Import the SocialIcon component"
  },
  "Icon Component": {
    "prefix": "icon",
    "body": [
      "<Icon name=\"${1|ChevronRight,X,Check,Plus,Search,Settings,User,Home,Menu,Trash2|}\" className=\"${2:h-5 w-5}\" />"
    ],
    "description": "Use the unified Icon component"
  },
  "Icon Import": {
    "prefix": "icon-import",
    "body": ["import { Icon } from '@/components/atoms/Icon';"],
    "description": "Import the unified Icon component"
  },
  "IconButton with Lucide": {
    "prefix": "iconbutton",
    "body": [
      "<IconButton ariaLabel=\"${1:Button description}\">",
      "  <${2:Settings} className=\"${3:h-4 w-4}\" />",
      "</IconButton>"
    ],
    "description": "IconButton component with Lucide React icon"
  },
  "IconBadge with Lucide": {
    "prefix": "iconbadge",
    "body": [
      "<IconBadge Icon={${1:Bolt}} colorVar=\"${2:--color-yellow-500}\" />"
    ],
    "description": "IconBadge component with Lucide React icon"
  },
  "Icon with Accessibility": {
    "prefix": "icon-a11y",
    "body": [
      "<${1:ChevronRight} ",
      "  className=\"${2:h-5 w-5}\" ",
      "  aria-label=\"${3:Icon description}\"",
      "  aria-hidden={${4|false,true|}}",
      "/>"
    ],
    "description": "Lucide icon with accessibility attributes"
  },
  "Social Icon with Accessibility": {
    "prefix": "socialicon-a11y",
    "body": [
      "<SocialIcon ",
      "  platform=\"${1|spotify,instagram,twitter,tiktok,youtube,facebook|}\"",
      "  className=\"${2:h-5 w-5}\"",
      "  aria-label=\"${3:Platform name}\"",
      "  aria-hidden={${4|false,true|}}",
      "/>"
    ],
    "description": "SocialIcon with accessibility attributes"
  },
  "Icon Size Classes": {
    "prefix": "icon-size",
    "body": ["className=\"${1|h-4 w-4,h-5 w-5,h-6 w-6,h-8 w-8|}\""],
    "description": "Standard icon size classes"
  },
  "Common Navigation Icons": {
    "prefix": "nav-icons",
    "body": [
      "// Navigation icons",
      "import { ",
      "  ChevronRight,",
      "  ChevronLeft,",
      "  ArrowRight,",
      "  ArrowLeft,",
      "  Home,",
      "  Menu,",
      "} from 'lucide-react';"
    ],
    "description": "Common navigation icons import"
  },
  "Common Action Icons": {
    "prefix": "action-icons",
    "body": [
      "// Action icons",
      "import { ",
      "  Plus,",
      "  X,",
      "  Pencil,",
      "  Trash2,",
      "  Share,",
      "  Search,",
      "  Settings,",
      "} from 'lucide-react';"
    ],
    "description": "Common action icons import"
  },
  "Common State Icons": {
    "prefix": "state-icons",
    "body": [
      "// State icons",
      "import { ",
      "  Check,",
      "  CheckCircle,",
      "  XCircle,",
      "  AlertTriangle,",
      "  Info,",
      "} from 'lucide-react';"
    ],
    "description": "Common state icons import"
  }
}
