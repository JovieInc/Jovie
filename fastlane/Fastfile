default_platform(:ios)
opt_out_usage

require "shellwords"
require "open3"
require "time"

REPO_ROOT = File.expand_path("..", __dir__)
IOS_PROJECT = File.join(REPO_ROOT, "apps/ios/Jovie.xcodeproj")
IOS_SCHEME = "Jovie"
APP_IDENTIFIER = "ie.jov.Jovie"
APP_NAME = "Jovie"
APP_SKU = "jovie-ios"
APP_VERSION = "1.0"
APP_PRIMARY_LOCALE = "en-US"
DEFAULT_ARTIFACT_DIR = File.join(REPO_ROOT, "artifacts/ios-build")

def require_env!(name)
  value = ENV[name].to_s
  UI.user_error!("Missing required environment variable #{name}") if value.empty?
  value
end

def env_present?(name)
  !ENV[name].to_s.strip.empty?
end

def repo_path(path)
  File.join(REPO_ROOT, path)
end

def app_store_api_key_from_env
  key_content = require_env!("APPLE_API_KEY")

  app_store_connect_api_key(
    key_id: require_env!("APPLE_API_KEY_ID"),
    issuer_id: require_env!("APPLE_API_ISSUER"),
    key_content: key_content,
    is_key_content_base64: !key_content.include?("BEGIN PRIVATE KEY"),
    duration: 1200
  )
end

def require_match_git_auth!
  return if env_present?("MATCH_GIT_PRIVATE_KEY") || env_present?("MATCH_GIT_BASIC_AUTHORIZATION")

  UI.user_error!("Missing match git authentication: set MATCH_GIT_PRIVATE_KEY or MATCH_GIT_BASIC_AUTHORIZATION")
end

def match_git_auth_options
  options = {}
  options[:git_private_key] = ENV["MATCH_GIT_PRIVATE_KEY"] if env_present?("MATCH_GIT_PRIVATE_KEY")
  options[:git_basic_authorization] = ENV["MATCH_GIT_BASIC_AUTHORIZATION"] if env_present?("MATCH_GIT_BASIC_AUTHORIZATION")
  options
end

def distribution_certificate_name(apple_team_id:)
  return ENV["APPLE_DISTRIBUTION_CERTIFICATE"] if env_present?("APPLE_DISTRIBUTION_CERTIFICATE")

  output, status = Open3.capture2e("security", "find-identity", "-v", "-p", "codesigning")
  UI.user_error!("Unable to inspect installed code signing identities") unless status.success?

  team_pattern = Regexp.escape(apple_team_id)
  matches = output.lines.filter_map do |line|
    line[/\"((?:Apple|iPhone) Distribution: [^\"]+ \(#{team_pattern}\))\"/, 1]
  end.uniq

  UI.user_error!("No Apple Distribution signing identity found for team #{apple_team_id}") if matches.empty?
  if matches.length > 1
    UI.user_error!(
      "Multiple Apple Distribution signing identities found for team #{apple_team_id}: #{matches.join(", ")}"
    )
  end

  matches.fetch(0)
end

def build_number
  ENV["IOS_BUILD_NUMBER"].to_s.empty? ? ENV.fetch("GITHUB_RUN_NUMBER", Time.now.utc.strftime("%Y%m%d%H%M")) : ENV["IOS_BUILD_NUMBER"]
end

def write_ios_configuration(api_base_url:, web_base_url:, clerk_publishable_key:)
  sh(
    [
      "API_BASE_URL=#{api_base_url.shellescape}",
      "WEB_BASE_URL=#{web_base_url.shellescape}",
      "CLERK_PUBLISHABLE_KEY=#{clerk_publishable_key.shellescape}",
      "bash #{repo_path("apps/ios/scripts/write-configuration.sh").shellescape}"
    ].join(" ")
  )
end

def ios_simulator_destination
  destination = sh("bash #{repo_path("apps/ios/scripts/run-xcodebuild.sh").shellescape} destination")
    .lines
    .map(&:strip)
    .find { |line| line.start_with?("platform=iOS Simulator") }
  UI.user_error!("Unable to resolve an iOS simulator destination") if destination.to_s.empty?

  destination
end

def reset_ios_simulator(destination:)
  simulator_id = destination[/id=([^,]+)/, 1]
  UI.user_error!("Unable to parse simulator id from destination #{destination}") if simulator_id.to_s.empty?

  sh("xcrun simctl shutdown #{simulator_id.shellescape} >/dev/null 2>&1 || true")
  sh("xcrun simctl boot #{simulator_id.shellescape} >/dev/null 2>&1 || true")
  sh("xcrun simctl bootstatus #{simulator_id.shellescape} -b")
  sh("xcrun simctl terminate #{simulator_id.shellescape} #{APP_IDENTIFIER.shellescape} >/dev/null 2>&1 || true")
end

def ensure_app_store_assets!(api_key:, apple_team_id:)
  bundle_id = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
  if bundle_id
    UI.message("Found Apple bundle identifier #{APP_IDENTIFIER}")
  else
    UI.message("Creating Apple bundle identifier #{APP_IDENTIFIER}")
    bundle_id = Spaceship::ConnectAPI::BundleId.create(
      name: APP_NAME,
      platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
      identifier: APP_IDENTIFIER,
      seed_id: apple_team_id
    )
  end

  associated_domains = Spaceship::ConnectAPI::BundleIdCapability::Type::ASSOCIATED_DOMAINS
  capabilities = bundle_id.get_capabilities
  unless capabilities.any? { |capability| capability.is_type?(associated_domains) }
    UI.message("Enabling Associated Domains for #{APP_IDENTIFIER}")
    bundle_id.create_capability(associated_domains)
  end

  app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
  if app
    UI.message("Found App Store Connect app record for #{APP_IDENTIFIER}")
    app.ensure_version!(APP_VERSION, platform: Spaceship::ConnectAPI::Platform::IOS)
  else
    UI.message("Creating App Store Connect app record for #{APP_IDENTIFIER}")
    Spaceship::ConnectAPI::App.create(
      name: APP_NAME,
      version_string: APP_VERSION,
      sku: APP_SKU,
      primary_locale: APP_PRIMARY_LOCALE,
      bundle_id: APP_IDENTIFIER,
      platforms: [Spaceship::ConnectAPI::Platform::IOS],
      company_name: ENV["APP_STORE_COMPANY_NAME"]
    )
  end
end

platform :ios do
  desc "Run unsigned iOS simulator tests"
  lane :ios_tests do
    sh("bash #{repo_path("apps/ios/scripts/ensure-configuration.sh").shellescape}")
    sh("bash #{repo_path("apps/ios/scripts/validate-app-icon.sh").shellescape}")
    destination = ios_simulator_destination
    reset_ios_simulator(destination: destination)

    scan(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      clean: true,
      destination: destination,
      output_directory: repo_path("artifacts/ios-test-results"),
      result_bundle: true,
      xcargs: "CODE_SIGNING_ALLOWED=NO"
    )
  end

  desc "Capture core iOS flow screenshots from simulator"
  lane :screenshots do
    sh("bash #{repo_path("apps/ios/scripts/capture-screenshots.sh").shellescape}")
  end

  desc "Create or refresh App Store signing assets in match storage"
  lane :bootstrap_signing do
    api_key = app_store_api_key_from_env
    apple_team_id = require_env!("APPLE_TEAM_ID")
    require_env!("MATCH_GIT_URL")
    require_env!("MATCH_PASSWORD")
    require_match_git_auth!

    setup_ci if ENV["CI"].to_s.downcase == "true"
    ensure_app_store_assets!(api_key: api_key, apple_team_id: apple_team_id)

    match(
      **{
        type: "appstore",
        app_identifier: APP_IDENTIFIER,
        team_id: apple_team_id,
        api_key: api_key,
        readonly: false
      }.merge(match_git_auth_options)
    )
  end

  desc "Archive and upload an internal TestFlight build"
  lane :beta do
    api_key = app_store_api_key_from_env
    apple_team_id = require_env!("APPLE_TEAM_ID")
    require_env!("MATCH_GIT_URL")
    require_env!("MATCH_PASSWORD")
    require_match_git_auth!

    clerk_domain = require_env!("CLERK_ASSOCIATED_DOMAIN")
    clerk_publishable_key = require_env!("CLERK_PUBLISHABLE_KEY")
    api_base_url = ENV.fetch("API_BASE_URL", "https://jov.ie")
    web_base_url = ENV.fetch("WEB_BASE_URL", "https://jov.ie")
    current_build_number = build_number

    write_ios_configuration(
      api_base_url: api_base_url,
      web_base_url: web_base_url,
      clerk_publishable_key: clerk_publishable_key
    )

    setup_ci if ENV["CI"].to_s.downcase == "true"

    ensure_app_store_assets!(api_key: api_key, apple_team_id: apple_team_id)

    match(
      **{
        type: "appstore",
        app_identifier: APP_IDENTIFIER,
        team_id: apple_team_id,
        api_key: api_key,
        readonly: ENV["CI"].to_s.downcase == "true"
      }.merge(match_git_auth_options)
    )

    distribution_certificate = distribution_certificate_name(apple_team_id: apple_team_id)
    profile_name = "match AppStore #{APP_IDENTIFIER}"
    update_code_signing_settings(
      path: IOS_PROJECT,
      use_automatic_signing: false,
      targets: [IOS_SCHEME],
      build_configurations: ["Release"],
      team_id: apple_team_id,
      code_sign_identity: distribution_certificate,
      profile_name: profile_name
    )

    signing_xcargs = [
      "CODE_SIGNING_ALLOWED=YES",
      "CODE_SIGNING_REQUIRED=YES",
      "CURRENT_PROJECT_VERSION=#{current_build_number.shellescape}",
      "CLERK_ASSOCIATED_DOMAIN=#{clerk_domain.shellescape}"
    ].join(" ")

    gym(
      project: IOS_PROJECT,
      scheme: IOS_SCHEME,
      configuration: "Release",
      clean: true,
      output_directory: DEFAULT_ARTIFACT_DIR,
      output_name: "Jovie.ipa",
      export_method: "app-store",
      xcargs: signing_xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        signingCertificate: distribution_certificate,
        teamID: apple_team_id,
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: File.join(DEFAULT_ARTIFACT_DIR, "Jovie.ipa"),
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: ENV.fetch("TESTFLIGHT_CHANGELOG", "Internal iOS foundation build #{current_build_number}")
    )
  end
end
