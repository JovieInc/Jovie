{
  "rules": [
    {
      "allowed": {
        "origins": ["http://localhost:3000"],
        "methods": ["GET", "PUT", "POST", "HEAD"],
        "headers": [
          "Content-Type",
          "Content-MD5",
          "Authorization",
          "x-amz-content-sha256",
          "x-amz-date",
          "x-amz-acl"
        ]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
