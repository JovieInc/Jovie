{
  "rules": [
    {
      "id": "archive-to-ia-after-30d",
      "enabled": true,
      "conditions": {
        "prefix": "archived/"
      },
      "storageClassTransitions": [
        {
          "condition": {
            "type": "Age",
            "maxAge": 2592000
          },
          "storageClass": "InfrequentAccess"
        }
      ]
    },
    {
      "id": "abort-orphan-multiparts-after-24h",
      "enabled": true,
      "conditions": {},
      "abortMultipartUploadsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 86400
        }
      }
    }
  ]
}
