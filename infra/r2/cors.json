{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:3000",
          "https://staging.jov.ie",
          "https://jov.ie"
        ],
        "methods": ["GET", "PUT", "POST", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
