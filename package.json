{
  "name": "jovie-monorepo",
  "version": "26.2.1",
  "private": true,
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.13.0 <23",
    "pnpm": "9.15.4"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "parse5": "7.1.2",
      "jws": "4.0.1",
      "path-to-regexp": ">=8.0.0",
      "express>path-to-regexp": "0.1.12",
      "esbuild": ">=0.25.0",
      "cookie": ">=1.0.0",
      "tmp": ">=0.2.3",
      "vite": "^6.3.5",
      "drizzle-orm": "0.45.1",
      "jsdom": "26.1.0",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "hono": ">=4.11.7",
      "diff": ">=8.0.3",
      "lodash": ">=4.17.23",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch@^10.0.0": "10.2.4",
      "minimatch@^9.0.0": "^9.0.7",
      "minimatch@~3.1.0": "3.1.5",
      "serialize-javascript": "^7.0.3",
      "rollup": "^4.59.0",
      "basic-ftp": "^5.2.0",
      "axios": "^1.13.5",
      "ajv@^8.0.0": "^8.18.0",
      "undici": "^6.23.0",
      "webpack": "5.105.0",
      "qs": "6.15.0"
    },
    "patchedDependencies": {
      "eslint-plugin-react@7.37.5": "patches/eslint-plugin-react@7.37.5.patch"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@jovie/web",
    "build": "turbo build",
    "build:web": "turbo build --filter=@jovie/web",
    "lint": "node scripts/run-scoped-turbo-task.mjs lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "node scripts/run-scoped-turbo-task.mjs typecheck",
    "test": "turbo test",
    "test:ci": "turbo test:ci",
    "test:fast": "turbo test:fast",
    "test:e2e": "turbo test:e2e",
    "test:guard": "pnpm --filter=@jovie/web run test:guard",
    "test:profile": "pnpm --filter=@jovie/web run test:profile",
    "test:flaky": "pnpm --filter=@jovie/web run test:flaky",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "biome:ci": "biome ci .",
    "biome:check": "biome check .",
    "commit": "cz",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky",
    "next:proxy-guard": "pnpm --filter=@jovie/web run next:proxy-guard",
    "pre-push": "biome check . && pnpm --filter=@jovie/web run pre-push",
    "tailwind:check": "pnpm --filter=@jovie/web run tailwind:check",
    "knip": "knip",
    "version:bump": "node scripts/version-bump.mjs",
    "version:check": "node scripts/version-check.mjs",
    "changelog:generate": "doppler run -- node scripts/generate-changelog.mjs",
    "changelog:send": "doppler run -- node scripts/send-changelog-email.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "knip": "^5.83.0",
    "lint-staged": "^16.2.6",
    "@anthropic-ai/sdk": "^0.78.0",
    "turbo": "^2.8.9",
    "typescript": "^5"
  },
  "lint-staged": {
    "apps/web/drizzle/migrations/**/*.{sql,ts}": [
      "pnpm --filter=@jovie/web run migration:validate",
      "pnpm --filter=@jovie/web run migration:guard"
    ],
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.js --max-warnings=0 --no-warn-ignored --cache --cache-location apps/web/.cache/eslint --cache-strategy content",
      "bash -c 'pnpm turbo typecheck --filter=@jovie/web'"
    ],
    "apps/web/components/**/*.{tsx,ts}": [
      "pnpm --filter=@jovie/web run a11y:check:staged"
    ],
    "*.{json,css}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
