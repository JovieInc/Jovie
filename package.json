{
  "name": "jovie-monorepo",
  "version": "26.4.197",
  "private": true,
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.13.0 <23",
    "pnpm": "9.15.4"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "parse5": "7.1.2",
      "jws": "4.0.1",
      "path-to-regexp": "8.4.2",
      "express>path-to-regexp": "0.1.13",
      "esbuild": ">=0.25.0",
      "cookie": ">=1.0.0",
      "tmp": ">=0.2.3",
      "vite": "6.4.2",
      "drizzle-orm": "0.45.2",
      "jsdom": "26.1.0",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "hono": ">=4.11.7",
      "diff": ">=8.0.3",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1",
      "handlebars": ">=4.7.9",
      "@xmldom/xmldom": ">=0.9.9",
      "brace-expansion": "5.0.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch@^10.0.0": "10.2.4",
      "minimatch@^9.0.0": "^9.0.7",
      "minimatch@~3.1.0": "3.1.5",
      "serialize-javascript": "^7.0.3",
      "rollup": "^4.60.0",
      "basic-ftp": "5.3.0",
      "axios": "^1.13.6",
      "ajv@^8.0.0": "^8.18.0",
      "undici": "^6.23.0",
      "webpack": "5.105.0",
      "qs": "6.15.0",
      "@vercel/microfrontends": "2.3.2",
      "follow-redirects": "1.16.0",
      "@clerk/ui>@floating-ui/react": "0.27.19",
      "tar": "7.5.13",
      "@tootallnate/once": "3.0.1",
      "smol-toml": "1.6.1",
      "srvx": "0.11.13"
    },
    "patchedDependencies": {
      "eslint-plugin-react@7.37.5": "patches/eslint-plugin-react@7.37.5.patch"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@jovie/web",
    "dev:web:local": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run dev:local",
    "dev:web:browse": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run dev:local:browse",
    "dev:web:fast": "bash scripts/dev-web-fast.sh",
    "ios:open": "open apps/ios/Jovie.xcodeproj",
    "ios:setup-env": "bash apps/ios/scripts/setup-env.sh",
    "ios:build": "bash apps/ios/scripts/run-xcodebuild.sh build",
    "ios:test": "bash apps/ios/scripts/run-xcodebuild.sh test",
    "build": "node scripts/turbo-local.mjs build",
    "build:web": "node scripts/turbo-local.mjs build --filter=@jovie/web",
    "lint": "node scripts/run-scoped-turbo-task.mjs lint",
    "lint:fix": "node scripts/turbo-local.mjs lint:fix",
    "typecheck": "node scripts/run-scoped-turbo-task.mjs typecheck",
    "test": "node scripts/turbo-local.mjs test",
    "test:web": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run test",
    "test:web:changed": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run test -- --changed",
    "test:web:watch": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run test:watch",
    "test:web:smoke": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run e2e:smoke",
    "test:web:e2e": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run test:e2e",
    "test:mobile-overflow": "doppler run --project jovie-web --config dev -- env E2E_USE_TEST_AUTH_BYPASS=1 NEXT_PUBLIC_CLERK_MOCK=1 NEXT_PUBLIC_CLERK_PROXY_DISABLED=1 pnpm --filter @jovie/web exec playwright test tests/e2e/mobile-overflow.spec.ts --project=chromium --reporter=line",
    "test:ci": "node scripts/turbo-local.mjs test:ci",
    "test:fast": "node scripts/turbo-local.mjs test:fast",
    "test:e2e": "node scripts/turbo-local.mjs test:e2e",
    "test:guard": "pnpm --filter=@jovie/web run test:guard",
    "test:profile": "pnpm --filter=@jovie/web run test:profile",
    "test:flaky": "pnpm --filter=@jovie/web run test:flaky",
    "admin:green": "doppler run --project jovie-web --config dev -- pnpm --filter=@jovie/web run admin:green",
    "admin:green:record": "doppler run --project jovie-web --config dev -- pnpm --filter=@jovie/web run admin:green:record",
    "admin:green:watch": "doppler run --project jovie-web --config dev -- pnpm --filter=@jovie/web run admin:green:watch",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "benchmark:dev": "doppler run --project jovie-web --config dev -- bash scripts/benchmark-dev.sh",
    "turbo:verify-cache": "node scripts/turbo-verify-cache.mjs",
    "biome:ci": "biome ci .",
    "biome:check": "biome check .",
    "commit": "cz",
    "clean": "node scripts/turbo-local.mjs clean && rm -rf node_modules",
    "prepare": "husky",
    "next:proxy-guard": "pnpm --filter=@jovie/web run next:proxy-guard",
    "typecheck:web:fast": "pnpm --filter @jovie/web exec tsc -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile .cache/tsbuildinfo --pretty false",
    "pre-push": "biome check . && pnpm --filter=@jovie/web run pre-push",
    "tailwind:check": "pnpm --filter=@jovie/web run tailwind:check",
    "db:web:migrate": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run drizzle:migrate",
    "db:web:studio": "doppler run --project jovie-web --config dev -- pnpm --filter @jovie/web run drizzle:studio",
    "knip": "knip",
    "version:check": "node scripts/version-check.mjs",
    "changelog:send": "doppler run -- node scripts/send-changelog-email.mjs",
    "video:footer:generate": "doppler run --project jovie-web --config dev -- tsx scripts/generate-footer-cta-video.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "1.58.2",
    "commitizen": "^4.3.1",
    "csv-parse": "^6.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "playwright": "1.58.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vercel": "52.0.0",
    "vitest": "4.1.4"
  },
  "lint-staged": {
    "apps/web/drizzle/migrations/**/*.{sql,ts}": [
      "pnpm --filter=@jovie/web run migration:validate",
      "pnpm --filter=@jovie/web run migration:guard"
    ],
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.js --max-warnings=0 --no-warn-ignored --cache --cache-location apps/web/.cache/eslint --cache-strategy content",
      "bash -c 'node scripts/turbo-local.mjs typecheck --filter=@jovie/web'"
    ],
    "apps/web/components/**/*.{tsx,ts}": [
      "pnpm --filter=@jovie/web run a11y:check:staged"
    ],
    "*.{json,css}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
