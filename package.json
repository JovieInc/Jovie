    "ios:screenshots": "bash apps/ios/scripts/capture-screenshots.sh",
    "build": "node scripts/turbo-local.mjs build",
    "build:web": "node scripts/turbo-local.mjs build --filter=@jovie/web",
    "auth:redirect-uris": "tsx scripts/auth-redirect-uris.ts",
    "brand:generate": "tsx scripts/generate-brand-assets.ts",
    "lint": "node scripts/run-scoped-turbo-task.mjs lint",
