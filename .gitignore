# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
apps/web/node_modules
/.pnp
.pnp.js

# testing
/coverage

# playwright
/playwright-report/

# test runner artifacts
/test-results/
/artifacts/
apps/web/test-results/
apps/web/artifacts/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.log
.eslintcache

# local env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
.cache/
next-env.d.ts

# Demo files
flyout-demo-updated.html

# Ignore generated sitemaps
public/sitemap*.xml
public/sitemap*.xml.gz

# Sentry Config File
.env.sentry-build-plugin
storybook-static/

# Claude Code — track config but ignore local worktrees and ephemeral data
.claude/worktrees/
.claude/projects/
.claude/teams/
.claude/tasks/
.claude_settings.json
.auto-claude*
.codex/

# App-specific node_modules and build output
apps/should-i-make/node_modules
apps/should-i-make/.next
packages/ui/node_modules

# Turborepo
.turbo
doppler.yaml

# Local git worktrees (should never be committed)
.worktrees/
/.issues/

# Screenshot pipeline artifacts
ideation/screenshots/

# npm lockfiles (pnpm monorepo uses pnpm-lock.yaml)
package-lock.json

# Auto Claude generated files
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.security-key
logs/security/
output/
.audit/
