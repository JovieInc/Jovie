# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
apps/web/node_modules
/.pnp
.pnp.js

# testing
/coverage
apps/web/coverage/
packages/ui/coverage/

# playwright
/playwright-report/

# test runner artifacts
/test-results/
/artifacts/
apps/web/test-results/
apps/web/artifacts/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.log
.eslintcache

# local env files
.env*

# vercel
.vercel

# Vercel Workflow DevKit local world state
.workflow-data/

# typescript
*.tsbuildinfo
.cache/
next-env.d.ts

# Demo files
flyout-demo-updated.html

# Ignore generated sitemaps
public/sitemap*.xml
public/sitemap*.xml.gz

# Sentry Config File
.env.sentry-build-plugin
storybook-static/

# Claude Code — track config but ignore local worktrees and ephemeral data
.claude/worktrees/
.claude/projects/
.claude/teams/
.claude/tasks/
.claude_settings.json
.auto-claude*
# Codex team config is tracked; runtime/local artifacts stay ignored.
.codex/*
!.codex/config.toml
!.codex/hooks.json
!.codex/local-env.toml

# App-specific node_modules and build output
apps/should-i-make/node_modules
apps/should-i-make/.next
packages/ui/node_modules

# Turborepo
.turbo
doppler.yaml

# Local git worktrees (should never be committed)
.worktrees/
/.issues/
# GBrain per-worktree source state
/.gbrain-source

# Screenshot pipeline artifacts
ideation/screenshots/

# npm lockfiles (pnpm monorepo uses pnpm-lock.yaml)
package-lock.json

# Xcode
DerivedData/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
apps/ios/Jovie/Configuration.local.plist

# Auto Claude generated files
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.security-key
logs/security/
output/
.audit/
.gstack/
.claude/skills/gstack/
.claude/scheduled_tasks.lock

# Ruflo MCP local state (sqlite + vector index, never committed)
.claude-flow/
.swarm/
ruvector.db

# AgentOS run artifacts (binary outputs not source-controlled)
agentos/runs/**/artifacts/
.hermes/
agentos/
docs/leads/
*.bak
*.bak2
*.backup
apps/web/exp/
apps/web/.final-shots/
apps/web/.tmp-polish-baseline/
apps/desktop/
apps/extension/
.agents/
