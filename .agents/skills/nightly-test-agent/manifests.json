{
  "version": 1,
  "repos": {
    "jovie": {
      "displayName": "Jovie",
      "mode": "deepen-and-prove",
      "language": "TypeScript",
      "frameworks": ["Next.js", "React", "Vitest", "Playwright", "fast-check"],
      "packageManager": "pnpm@9.15.4",
      "commands": {
        "typecheckTests": "pnpm --filter=@jovie/web exec tsc -p tsconfig.test.json --noEmit --incremental false",
        "unit": "CI=true pnpm --filter=@jovie/web run test",
        "unitCoverage": "CI=true pnpm --filter=@jovie/web run test -- --coverage",
        "nightlyE2E": "pnpm --filter=@jovie/web exec playwright test --config=playwright.config.nightly.ts --project=chromium",
        "flake": "pnpm --filter=@jovie/web run test:flaky",
        "mutationHotspots": "pnpm --filter=@jovie/web run test:mutation:hotspots"
      },
      "nightlyBudget": {
        "maxTargets": 8,
        "mutationMinutes": 30,
        "maxGeneratedTests": 3
      },
      "riskWeights": {
        "criticality": 22,
        "recentFailure": 16,
        "mutationSurvivor": 9,
        "flake": 12,
        "duration": 4,
        "quarantine": 14
      },
      "protectedPathPrefixes": [
        "apps/web/app/api/stripe/",
        "apps/web/app/api/billing/",
        "apps/web/app/api/clerk/",
        "apps/web/lib/auth/",
        "apps/web/lib/entitlements/",
        "apps/web/lib/stripe/",
        "apps/web/lib/billing/",
        "apps/web/lib/onboarding/",
        "apps/web/proxy.ts",
        "apps/web/drizzle/migrations/"
      ],
      "generationPolicy": {
        "allowAutoPersist": false,
        "requireMutationOrCoverageSignal": true,
        "stabilityReruns": 3,
        "preferModes": ["property", "unit", "integration", "model", "e2e"]
      },
      "quarantine": [
        {
          "id": "tests/contracts/dashboard-apis.spec.ts",
          "lane": "unit",
          "owner": "web",
          "exitCriteria": "Remove after 5 consecutive nightly passes"
        },
        {
          "id": "tests/unit/dashboard/SettingsAdPixelsSection.test.tsx",
          "lane": "unit",
          "owner": "web",
          "exitCriteria": "Remove after 5 consecutive nightly passes"
        },
        {
          "id": "apps/web/tests/e2e/dashboard-pages-health.spec.ts",
          "lane": "e2e",
          "owner": "web",
          "exitCriteria": "Remove after 5 consecutive nightly passes"
        }
      ],
      "riskItems": [
        {
          "id": "billing-plan-change",
          "module": "Billing plan changes",
          "owner": "web",
          "criticality": 5,
          "kind": "workflow",
          "reasons": [
            "Money path",
            "Plan downgrade and checkout regressions are high blast radius"
          ],
          "paths": [
            "apps/web/lib/stripe/plan-change.ts",
            "apps/web/lib/billing/"
          ],
          "relatedTests": [
            "apps/web/tests/unit/lib/queries/useBillingMutations.test.tsx"
          ],
          "lanes": ["unit", "integration", "mutation", "generation"],
          "generatedTestBudget": 1
        },
        {
          "id": "stripe-connect-readiness",
          "module": "Stripe Connect readiness",
          "owner": "web",
          "criticality": 5,
          "kind": "api-contract",
          "reasons": [
            "Payment onboarding trust boundary",
            "Already has focused unit coverage worth mutation testing"
          ],
          "paths": ["apps/web/lib/stripe/connect-readiness.ts"],
          "relatedTests": ["apps/web/lib/stripe/connect-readiness.test.ts"],
          "lanes": ["unit", "mutation"],
          "generatedTestBudget": 1
        },
        {
          "id": "cron-auth",
          "module": "Cron authentication",
          "owner": "web",
          "criticality": 5,
          "kind": "api-contract",
          "reasons": [
            "Scheduled tasks must fail closed",
            "Cron auth regressions can expose public maintenance routes"
          ],
          "paths": ["apps/web/lib/cron/auth.ts", "apps/web/app/api/cron/"],
          "relatedTests": ["apps/web/lib/cron/auth.test.ts"],
          "lanes": ["unit", "mutation", "generation"],
          "generatedTestBudget": 1
        },
        {
          "id": "onboarding-state",
          "module": "Onboarding state transitions",
          "owner": "web",
          "criticality": 5,
          "kind": "state-machine",
          "reasons": [
            "Profile ownership and claim trust path",
            "Failures strand new creators"
          ],
          "paths": [
            "apps/web/lib/onboarding/",
            "apps/web/app/(onboarding)/",
            "apps/web/app/onboarding/"
          ],
          "relatedTests": [
            "apps/web/tests/unit/actions/onboarding/validation.test.ts",
            "apps/web/tests/e2e/onboarding-completion.spec.ts"
          ],
          "lanes": ["unit", "e2e", "mutation", "generation"],
          "generatedTestBudget": 1
        },
        {
          "id": "entitlements-source-of-truth",
          "module": "Entitlements resolver",
          "owner": "web",
          "criticality": 5,
          "kind": "workflow",
          "reasons": [
            "Plan authorization source of truth",
            "Security rule requires getCurrentUserEntitlements"
          ],
          "paths": ["apps/web/lib/entitlements/"],
          "relatedTests": [
            "apps/web/tests/unit/lib/entitlements.server.test.ts"
          ],
          "lanes": ["unit", "mutation"],
          "generatedTestBudget": 1
        },
        {
          "id": "public-profile-rendering",
          "module": "Public profile rendering",
          "owner": "web",
          "criticality": 4,
          "kind": "critical-user-journey",
          "reasons": [
            "Public creator pages are the core product surface",
            "Synthetic monitoring already covers smoke paths"
          ],
          "paths": [
            "apps/web/app/[username]/",
            "apps/web/tests/e2e/public-profile-smoke.spec.ts"
          ],
          "relatedTests": [
            "apps/web/tests/e2e/public-profile-smoke.spec.ts",
            "apps/web/tests/e2e/profile.spec.ts"
          ],
          "lanes": ["e2e", "flake", "generation"],
          "generatedTestBudget": 1,
          "cannotBeProvedLower": true
        },
        {
          "id": "validation-schemas",
          "module": "Validation schemas",
          "owner": "web",
          "criticality": 4,
          "kind": "validator",
          "reasons": [
            "High leverage for property-based generation",
            "Fast deterministic coverage"
          ],
          "paths": ["apps/web/lib/validation/"],
          "relatedTests": ["apps/web/constants/platforms/utils.fuzz.test.ts"],
          "lanes": ["unit", "mutation", "generation"],
          "generatedTestBudget": 1
        }
      ]
    },
    "ops": {
      "displayName": "Ops",
      "mode": "baseline-and-standardize",
      "language": "TypeScript",
      "frameworks": ["Next.js", "React", "Vitest"],
      "packageManager": "pnpm@9.15.4",
      "commands": {
        "unit": "pnpm test",
        "unitCoverage": "pnpm vitest run --coverage"
      },
      "nightlyBudget": {
        "maxTargets": 4,
        "mutationMinutes": 0,
        "maxGeneratedTests": 1
      },
      "riskWeights": {
        "criticality": 24,
        "recentFailure": 18,
        "mutationSurvivor": 0,
        "flake": 12,
        "duration": 4,
        "quarantine": 12
      },
      "protectedPathPrefixes": [],
      "generationPolicy": {
        "allowAutoPersist": false,
        "requireMutationOrCoverageSignal": false,
        "stabilityReruns": 3,
        "preferModes": ["unit", "integration", "property"]
      },
      "quarantine": [],
      "riskItems": [
        {
          "id": "ops-proxy-contract",
          "module": "Proxy and route contract",
          "owner": "ops",
          "criticality": 4,
          "kind": "api-contract",
          "reasons": [
            "Thin repo should first standardize request boundary tests"
          ],
          "paths": ["proxy.ts", "middleware.ts", "app/"],
          "relatedTests": [],
          "lanes": ["unit", "integration", "generation"],
          "generatedTestBudget": 1
        }
      ]
    }
  }
}
