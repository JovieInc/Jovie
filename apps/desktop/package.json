{
  "name": "@jovie/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/write-env.mjs",
    "dev": "tsc && electron .",
    "prebuild:staging": "cross-env ELECTRON_ENV=staging node scripts/write-env.mjs",
    "build:staging": "tsc && electron-builder --config electron-builder.staging.yml --publish always",
    "prebuild:production": "cross-env ELECTRON_ENV=production node scripts/write-env.mjs",
    "build:production": "tsc && electron-builder --config electron-builder.yml --publish always",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.33.0",
    "typescript": "^5.7.0"
  }
}
