{
  "name": "@jovie/desktop",
  "version": "26.5.13",
  "description": "Jovie desktop app",
  "author": "Jovie Inc.",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "cross-env ELECTRON_ENV=local node scripts/write-env.mjs",
    "dev": "tsc && electron .",
    "prepare:assets": "node scripts/prepare-icons.mjs && node scripts/generate-dmg-background.mjs",
    "prepare:dmg-background": "node scripts/generate-dmg-background.mjs",
    "test:desktop-shell": "node --test scripts/desktop-shell-contract.test.mjs",
    "test:dmg-background": "node --test scripts/generate-dmg-background.test.mjs",
    "test:release-guard": "node --test ../../scripts/desktop-release-guard.test.mjs",
    "prebuild:staging": "node scripts/sync-version.mjs && cross-env ELECTRON_ENV=staging node scripts/write-env.mjs && pnpm run prepare:assets",
    "build:staging": "tsc && electron-builder --config electron-builder.staging.yml --publish always",
    "prebuild:production": "node scripts/sync-version.mjs && cross-env ELECTRON_ENV=production node scripts/write-env.mjs && pnpm run prepare:assets",
    "build:production": "tsc && electron-builder --config electron-builder.yml --publish always",
    "prepackage:staging": "node scripts/sync-version.mjs && cross-env ELECTRON_ENV=staging node scripts/write-env.mjs && pnpm run prepare:assets",
    "package:staging": "tsc && electron-builder --config electron-builder.staging.yml --publish never",
    "prepackage:production": "node scripts/sync-version.mjs && cross-env ELECTRON_ENV=production node scripts/write-env.mjs && pnpm run prepare:assets",
    "package:production": "tsc && electron-builder --config electron-builder.yml --publish never",
    "pretypecheck": "node scripts/write-env.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.33.0",
    "typescript": "^5.7.0"
  }
}
