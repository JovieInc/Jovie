{
  "name": "@jovie/web",
  "version": "26.4.159",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 doppler run -- next dev",
    "dev:local": "next dev",
    "dev:local:browse": "E2E_USE_TEST_AUTH_BYPASS=1 NEXT_PUBLIC_CLERK_MOCK=1 NEXT_PUBLIC_CLERK_PROXY_DISABLED=1 next dev",
    "dev:local:playwright": "next dev --webpack",
    "validate-env": "tsx scripts/validate-env.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 NEXT_IGNORE_TYPECHECK=1 next build --turbopack",
    "build:strict": "pnpm run typecheck && NODE_OPTIONS=--max-old-space-size=8192 next build --turbopack",
    "analyze": "NODE_OPTIONS=--max-old-space-size=8192 ANALYZE=true NEXT_IGNORE_TYPECHECK=1 next build --webpack",
    "compare-chunks": "tsx scripts/compare-chunks.ts",
    "compare-chunks:snapshot": "tsx scripts/compare-chunks.ts --snapshot",
    "build:validate": "pnpm run validate-env && pnpm run build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:eslint": "eslint --max-warnings=0 --cache --cache-location .cache/eslint --cache-strategy content .",
    "lint:server-boundaries": "node scripts/run-server-boundary-eslint.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile .cache/tsbuildinfo",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit --incremental",
    "next:proxy-guard": "node scripts/next-proxy-guard.mjs",
    "pre-push": "pnpm run next:proxy-guard && pnpm run tailwind:check && pnpm run typecheck && pnpm run lint",
    "ship": "pnpm run migration:guard && pnpm run migration:validate && pnpm run drizzle:migrate && pnpm run drizzle:check && pnpm run typecheck && pnpm run lint && pnpm run test",
    "ship:pr": "tsx scripts/ship-pr.ts",
    "check": "pnpm run validate && pnpm run build && pnpm run test",
    "check:ci": "pnpm run validate && pnpm run test:ci",
    "validate": "pnpm run next:proxy-guard && pnpm run biome:check && pnpm run typecheck",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 node scripts/vitest-wrapper.mjs",
    "test:ci": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --pool=forks --maxWorkers=2",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --config=vitest.config.mts",
    "test:fast": "vitest run --config=vitest.config.fast.mts",
    "test:profile": "tsx scripts/test-performance-profiler.ts",
    "test:guard": "tsx scripts/test-performance-guard.ts",
    "test:budgets": "tsx scripts/performance-budgets-guard.ts",
    "test:budgets:launch": "tsx scripts/performance-launch-check.ts",
    "test:lighthouse:pr": "BASE_URL=${BASE_URL:-http://localhost:3000} lhci autorun --config=.lighthouserc.pr.json --collect.url=$BASE_URL/ --collect.url=$BASE_URL/tim",
    "test:lighthouse:public:launch": "tsx scripts/run-public-lighthouse.ts",
    "test:lighthouse:dashboard:pr": "node scripts/lighthouse-dashboard-auth.cjs",
    "test:lighthouse:onboarding:pr": "LIGHTHOUSE_CONFIG=.lighthouserc.onboarding.pr.json LIGHTHOUSE_DASHBOARD_URLS=/onboarding node scripts/lighthouse-dashboard-auth.cjs",
    "test:lighthouse:admin:pr": "LIGHTHOUSE_CONFIG=.lighthouserc.admin.pr.json LIGHTHOUSE_DASHBOARD_URLS=/app/admin/growth,/app/admin/creators,/app/admin/users,/app/admin/releases LIGHTHOUSE_TEST_PERSONA=admin node scripts/lighthouse-dashboard-auth.cjs",
    "test:flaky": "tsx scripts/flaky-test-detector.ts",
    "test:e2e": "playwright test",
    "test:e2e:fast": "node scripts/run-playwright-fast.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:synthetic": "playwright test --config=playwright.synthetic.config.ts",
    "test:e2e:golden-path": "playwright test tests/e2e/golden-path.spec.ts",
    "test:e2e:golden-path:ci": "CI=true playwright test tests/e2e/golden-path.spec.ts --project=chromium",
    "admin:seed": "NODE_OPTIONS=--conditions=react-server tsx tests/seed-admin-test-data.ts",
    "admin:visual": "playwright test tests/e2e/admin-visual-regression.spec.ts",
    "admin:visual:update": "playwright test tests/e2e/admin-visual-regression.spec.ts --update-snapshots",
    "admin:green": "tsx scripts/admin-green-loop.ts verify",
    "admin:green:record": "tsx scripts/admin-green-loop.ts record",
    "admin:green:watch": "tsx scripts/admin-green-loop.ts watch",
    "demo:record": "bash scripts/record-yc-demo.sh",
    "test:e2e:sentry:red": "node scripts/run-sentry-red-lane.mjs",
    "e2e:smoke": "SMOKE_ONLY=1 E2E_FAST_ITERATION=1 playwright test -g @smoke",
    "e2e:auth-smoke": "SMOKE_ONLY=1 playwright test tests/e2e/smoke-auth.spec.ts",
    "e2e:smoke:noauth": "playwright test -g @smoke --config=playwright.config.noauth.ts",
    "e2e:full": "playwright test",
    "e2e:full:fast": "node scripts/run-playwright-fast.mjs",
    "e2e:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "e2e:visual:update": "playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
    "screenshots": "pnpm run screenshots:seed && pnpm run screenshots:capture",
    "screenshots:capture": "playwright test --config=playwright.config.screenshots.ts",
    "screenshots:seed": "tsx tests/product-screenshots/seed.ts",
    "e2e:full:noauth": "playwright test --config=playwright.config.noauth.ts",
    "e2e:chaos": "playwright test --config=playwright.config.nightly.ts tests/e2e/nightly/chaos-click-testing.spec.ts",
    "e2e:chaos:extended": "CHAOS_EXTENDED=1 playwright test --config=playwright.config.nightly.ts -g 'extended'",
    "a11y:ci": "playwright test -g @a11y",
    "a11y:axe": "playwright test tests/e2e/axe-audit.spec.ts",
    "a11y:check:staged": "biome lint .",
    "a11y:fix": "biome check --write .",
    "a11y:fix:unsafe": "biome check --write --unsafe .",
    "a11y:report": "biome lint --reporter=json . > a11y-report.json",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "biome:ci": "biome ci .",
    "biome:check": "biome check .",
    "clean": "rm -rf .next out dist coverage .nyc_output",
    "postbuild": "next-sitemap && if [ \"${VERCEL_ENV:-}\" = \"preview\" ] || [ \"${VERCEL_SKIP_STANDALONE_ASSET_SYNC:-false}\" = \"true\" ]; then echo 'Skipping standalone asset sync for Vercel preview build'; else node ./scripts/sync-standalone-assets.mjs; fi",
    "verify-artist-images": "node scripts/verify-artist-images.js",
    "update-artist-images": "node scripts/update-artist-images.js",
    "ensure-valid-artist-images": "node scripts/ensure-valid-artist-images.js",
    "audit:icons": "node scripts/audit-icons.js",
    "danger": "danger ci --fail-on-errors --verbose",
    "db:migrate": "doppler run -- tsx scripts/drizzle-migrate.ts",
    "db:seed": "doppler run -- tsx scripts/drizzle-seed.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "doppler run -- tsx scripts/drizzle-migrate.ts",
    "drizzle:migrate:ci": "tsx scripts/drizzle-migrate.ts",
    "drizzle:verify": "doppler run -- tsx scripts/drizzle-migrate-verify.ts",
    "drizzle:verify:ci": "tsx scripts/drizzle-migrate-verify.ts",
    "drizzle:migrate:preflight": "doppler run -- tsx scripts/drizzle-migrate-preflight.ts",
    "drizzle:migrate:preview": "doppler run -c stg -- GIT_BRANCH=preview tsx scripts/drizzle-migrate.ts",
    "drizzle:migrate:prod": "doppler run -c prd -- GIT_BRANCH=production tsx scripts/drizzle-migrate.ts",
    "drizzle:push": "doppler run -- drizzle-kit push",
    "neon:migrate:preview": "doppler run -- tsx scripts/neon-migrate-preview.ts",
    "neon:migrate:preview:compare": "doppler run -- tsx scripts/neon-migrate-preview.ts --compare",
    "neon:migration:status": "doppler run -- tsx scripts/neon-migration-status.ts",
    "neon:init:migration-history": "doppler run -- tsx scripts/neon-init-migration-history.ts",
    "migration:guard": "bash scripts/check-migrations.sh origin/main",
    "migration:validate": "bash scripts/validate-migrations.sh",
    "migration:multi-check": "bash scripts/handle-multiple-migrations.sh --info",
    "migration:allow-multiple": "bash scripts/handle-multiple-migrations.sh --bulk",
    "migration:skip-guard": "bash scripts/handle-multiple-migrations.sh --skip",
    "drizzle:studio": "doppler run -- drizzle-kit studio",
    "drizzle:check": "drizzle-kit check",
    "db:validate": "doppler run -- tsx scripts/validate-db-schema.ts",
    "drizzle:up": "drizzle-kit up",
    "tailwind:check": "node scripts/tailwind-guard.mjs",
    "tailwind:guard": "node scripts/tailwind-guard.mjs",
    "generate": "plop",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:build": "storybook build",
    "storybook:test": "vitest --config=vitest.config.storybook.mts",
    "test:a11y": "vitest run --config=vitest.config.storybook.mts",
    "test:visual-a11y": "pnpm run e2e:visual && pnpm run test:a11y",
    "perf:auth": "tsx scripts/performance-auth.ts",
    "perf:queue": "doppler run --project jovie-web --config dev -- tsx scripts/performance-batch-queue.ts",
    "qa:routes": "tsx scripts/route-qa.ts",
    "public:route-qa": "tsx scripts/public-route-qa.ts",
    "qa:public:exhaustive": "tsx scripts/public-surface-qa.ts",
    "qa:public:exhaustive:staging": "BASE_URL=https://staging.jov.ie E2E_SKIP_WEB_SERVER=1 tsx scripts/public-surface-qa.ts",
    "qa:overnight": "tsx scripts/overnight-qa-controller.ts",
    "qa:overnight:resume": "tsx scripts/overnight-qa-controller.ts --resume",
    "qa:overnight:status": "tsx scripts/overnight-qa-controller.ts --status",
    "qa:overnight:dry-run": "tsx scripts/overnight-qa-controller.ts --dry-run",
    "perf:loop": "tsx scripts/performance-optimizer.ts",
    "perf:loop:end-user": "tsx scripts/performance-optimizer.ts --scope end-user",
    "perf:overnight": "tsx scripts/performance-overnight.ts",
    "qa:releases:loop": "tsx scripts/releases-dashboard-qa-loop.ts"
  },
