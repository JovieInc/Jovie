{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": ["http://localhost:3000/", "http://localhost:3000/tim"]
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "errors-in-console": "warn",
        "interactive": [
          "warn",
          {
            "maxNumericValue": 5000
          }
        ],
        "first-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 3500
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 5000
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.15
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 1500
          }
        ],
        "speed-index": [
          "warn",
          {
            "maxNumericValue": 6000
          }
        ],
        "max-potential-fid": "warn",
        "mainthread-work-breakdown": "warn",
        "render-blocking-resources": "off",
        "render-blocking-insight": "off",
        "legacy-javascript-insight": "warn",
        "unused-javascript": "warn",
        "color-contrast": "warn",
        "image-delivery-insight": "warn",
        "document-latency-insight": "warn",
        "is-crawlable": "off",
        "forced-reflow-insight": "warn",
        "network-dependency-tree-insight": "off",
        "target-size": "warn",
        "digest-mismatch": "off"
      },
      "assertMatrix": [
        {
          "matchingUrlPattern": "http://localhost:3000/$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.6
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.85
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.7
              }
            ],
            "categories:seo": [
              "warn",
              {
                "minScore": 0.6
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/tim/?$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.6
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.85
              }
            ],
            "categories:best-practices": [
              "warn",
              {
                "minScore": 0.7
              }
            ],
            "categories:seo": [
              "warn",
              {
                "minScore": 0.6
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
