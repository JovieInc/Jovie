{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/legal/privacy",
        "http://localhost:3000/legal/terms",
        "http://localhost:3000/legal/cookies"
      ]
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "http://localhost:3000/$",
          "preset": "lighthouse:no-pwa",
          "assertions": {
            "errors-in-console": "warn",
            "interactive": ["warn", { "maxNumericValue": 4000 }],
            "first-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
            "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
            "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
            "total-blocking-time": ["warn", { "maxNumericValue": 1500 }],
            "speed-index": ["warn", { "maxNumericValue": 5000 }],
            "max-potential-fid": "off",
            "mainthread-work-breakdown": "off",
            "render-blocking-resources": "off",
            "render-blocking-insight": "off",
            "lcp-discovery-insight": "off",
            "lcp-lazy-loaded": "warn",
            "legacy-javascript": "off",
            "legacy-javascript-insight": "off",
            "uses-responsive-images": "warn",
            "unused-javascript": "off",
            "color-contrast": "warn",
            "image-delivery-insight": "warn",
            "document-latency-insight": "warn",
            "dom-size": "warn",
            "dom-size-insight": "warn",
            "categories:performance": ["error", { "minScore": 0.4 }],
            "categories:accessibility": ["error", { "minScore": 0.85 }],
            "categories:best-practices": ["warn", { "minScore": 0.7 }],
            "categories:seo": ["warn", { "minScore": 0.6 }],
            "is-crawlable": "off",
            "forced-reflow-insight": "warn",
            "network-dependency-tree-insight": "off",
            "target-size": "warn",
            "digest-mismatch": "off"
          }
        },
        {
          "matchingUrlPattern": "http://localhost:3000/legal/(privacy|terms|cookies)$",
          "assertions": {
            "errors-in-console": "warn",
            "interactive": ["error", { "maxNumericValue": 5000 }],
            "first-contentful-paint": ["error", { "maxNumericValue": 3000 }],
            "largest-contentful-paint": ["error", { "maxNumericValue": 5000 }],
            "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
            "total-blocking-time": ["error", { "maxNumericValue": 1000 }],
            "speed-index": ["error", { "maxNumericValue": 4000 }],
            "categories:performance": ["error", { "minScore": 0.5 }],
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["error", { "minScore": 0.8 }],
            "categories:seo": ["error", { "minScore": 0.8 }],
            "button-name": "error",
            "color-contrast": "error",
            "document-title": "error",
            "html-has-lang": "error",
            "meta-description": "error"
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
