{
  "version": 1,
  "description": "SEO/AEO ratchet baseline (JovieInc/Jovie#11044). Lists routes that are SEO-clean and the signals they must maintain. Update only via intentional PR — the test hard-fails when a baseline-clean route loses required coverage.",
  "routes": [
    {
      "path": "app/(home)/page.tsx",
      "checks": [
        "metadata-export",
        "description",
        "openGraph",
        "twitter",
        "canonical",
        "json-ld"
      ]
    },
    {
      "path": "app/(marketing)/pricing/page.tsx",
      "checks": ["metadata-export", "description", "openGraph", "twitter"]
    },
    {
      "path": "app/(marketing)/about/page.tsx",
      "checks": ["metadata-export", "description", "openGraph", "canonical"]
    },
    {
      "path": "app/(marketing)/blog/page.tsx",
      "checks": ["metadata-export", "description", "canonical"]
    },
    {
      "path": "app/(marketing)/blog/[slug]/page.tsx",
      "checks": [
        "metadata-export",
        "description",
        "openGraph",
        "twitter",
        "canonical"
      ]
    },
    {
      "path": "app/(marketing)/support/page.tsx",
      "checks": ["metadata-export", "description", "canonical"]
    },
    {
      "path": "app/(marketing)/changelog/page.tsx",
      "checks": ["metadata-export", "description", "canonical"]
    },
    {
      "path": "app/[username]/page.tsx",
      "checks": [
        "metadata-export",
        "description",
        "openGraph",
        "twitter",
        "canonical",
        "json-ld"
      ]
    },
    {
      "path": "app/[username]/[slug]/page.tsx",
      "checks": [
        "metadata-export",
        "description",
        "openGraph",
        "twitter",
        "canonical",
        "json-ld"
      ]
    },
    {
      "path": "app/[username]/[slug]/[trackSlug]/page.tsx",
      "checks": ["metadata-export", "json-ld"]
    },
    {
      "path": "app/[username]/merch/[cardId]/page.tsx",
      "checks": ["metadata-export", "description", "openGraph", "json-ld"]
    }
  ]
}
