{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "puppeteerScript": "scripts/lighthouse-dashboard-auth.cjs",
      "settings": {
        "disableStorageReset": true
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "\\/app$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.8
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.06
              }
            ],
            "first-contentful-paint": [
              "error",
              {
                "maxNumericValue": 1100
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2200
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 225
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "\\/app\\/dashboard\\/releases$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.8
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.06
              }
            ],
            "first-contentful-paint": [
              "error",
              {
                "maxNumericValue": 1100
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2200
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 225
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/dashboard-pr"
    }
  }
}
