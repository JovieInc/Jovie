{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "puppeteerScript": "scripts/lighthouse-dashboard-auth.cjs",
      "puppeteerLaunchOptions": {
        "defaultViewport": {
          "width": 1350,
          "height": 940
        },
        "args": [
          "--disable-backgrounding-occluded-windows",
          "--disable-renderer-backgrounding",
          "--disable-background-timer-throttling",
          "--window-size=1350,940"
        ]
      },
      "settings": {
        "disableStorageReset": true
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "\\/app$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.8
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "first-contentful-paint": [
              "error",
              {
                "maxNumericValue": 1500
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2500
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 300
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "\\/app\\/dashboard\\/releases$",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.8
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "first-contentful-paint": [
              "error",
              {
                "maxNumericValue": 1500
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2500
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 500
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/dashboard-pr"
    }
  }
}
