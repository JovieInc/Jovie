{
  "schemaVersion": 1,
  "routes": [
    {
      "path": "/",
      "sourceFile": "app/(home)/page.tsx",
      "required": ["title", "description", "canonical", "openGraph", "twitter"],
      "jsonLd": true
    },
    {
      "path": "/about",
      "sourceFile": "app/(marketing)/about/page.tsx",
      "required": ["title", "description", "canonical", "openGraph"],
      "jsonLd": true
    },
    {
      "path": "/pricing",
      "sourceFile": "app/(marketing)/pricing/layout.tsx",
      "required": ["title", "description", "canonical", "openGraph", "twitter"],
      "jsonLd": false
    },
    {
      "path": "/support",
      "sourceFile": "app/(marketing)/support/page.tsx",
      "required": ["title", "description", "canonical", "openGraph"],
      "jsonLd": true
    },
    {
      "path": "/artist-profiles",
      "sourceFile": "app/(marketing)/artist-profiles/page.tsx",
      "required": ["title", "description", "canonical", "openGraph", "twitter"],
      "jsonLd": false
    },
    {
      "path": "/download",
      "sourceFile": "app/(marketing)/download/page.tsx",
      "required": ["title", "description", "canonical", "openGraph", "twitter"],
      "jsonLd": true
    },
    {
      "path": "/blog",
      "sourceFile": "app/(marketing)/blog/page.tsx",
      "required": ["title", "description", "canonical"],
      "jsonLd": false
    },
    {
      "path": "/changelog",
      "sourceFile": "app/(marketing)/changelog/page.tsx",
      "required": ["title", "description", "canonical"],
      "jsonLd": false
    }
  ],
  "profileSurfaces": [
    {
      "id": "public-profile",
      "sourceFile": "app/[username]/page.tsx",
      "jsonLd": true,
      "metadataBuilder": "buildPublicProfileMetadata"
    },
    {
      "id": "public-release-or-track",
      "sourceFile": "app/[username]/[slug]/page.tsx",
      "jsonLd": true,
      "requireGenerateMetadata": true
    }
  ],
  "robots": {
    "requiredAiCrawlers": [
      "GPTBot",
      "ChatGPT-User",
      "Claude-Web",
      "PerplexityBot",
      "Google-Extended"
    ],
    "productionSitemapUrl": "https://jov.ie/sitemap.xml",
    "forbiddenWildcardDisallow": "/"
  },
  "sitemap": {
    "minEntries": 1,
    "requireLastModified": true
  }
}
