{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "puppeteerScript": "scripts/lighthouse-dashboard-auth.cjs",
      "settings": {
        "disableStorageReset": true
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "\\/onboarding",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.85
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.8
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "first-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2000
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 3000
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 400
              }
            ],
            "speed-index": [
              "warn",
              {
                "maxNumericValue": 3500
              }
            ],
            "interactive": [
              "warn",
              {
                "maxNumericValue": 3500
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/onboarding-pr"
    }
  }
}
