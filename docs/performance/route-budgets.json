        "fcp_ms": 1500,
        "cls": 0.1,
        "tti_ms": 3000
      }
    },
    "marketing": {
      "description": "Marketing and legal pages",
      "examples": ["/", "/legal/privacy", "/playlists/[slug]"],
      "budgets": {
        "initialJS_gzip_kb": 150,
        "lcp_ms": 2000,
        "fcp_ms": 1200,
        "cls": 0.05,
        "tti_ms": 2500
      }
    },
    "dashboard": {
      "description": "Authenticated dashboard routes",
