{
  "schemaVersion": 1,
  "agentsMap": {
    "path": "CLAUDE.md",
    "maxLines": 120
  },
  "crossLinkScopes": [
    "CLAUDE.md",
    "CODEX.md",
    ".claude/rules/*.md",
    "docs/AI_AGENT_GUIDE.md",
    "docs/API_ROUTE_MAP.md",
    "docs/CRON_REGISTRY.md",
    "docs/PR_FLOW.md",
    "docs/WEBHOOK_MAP.md",
    "docs/TESTING_STRATEGY.md",
    "docs/PR_WORKFLOW_GUIDE.md",
    "docs/marketing/*.md"
  ],
  "gardeningScopes": ["docs/doc-gardening/**/*.md"],
  "computers": {
    "scoped-rules-count": {
      "description": "Topic-scoped rule files under .claude/rules/",
      "type": "globCount",
      "pattern": ".claude/rules/*.md"
    }
  },
  "freshnessMarkers": [
    {
      "id": "scoped-rules-count",
      "files": ["CLAUDE.md"],
      "computer": "scoped-rules-count"
    },
    {
      "id": "scoped-rules-count",
      "files": ["docs/doc-gardening/SEED-STALE.md"],
      "computer": "scoped-rules-count",
      "gardeningOnly": true
    }
  ]
}
